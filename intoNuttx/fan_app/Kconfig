#
# For a description of the syntax of this configuration file,
# see the file kconfig-language.txt in the NuttX tools repository.
#

config CUSTOM_APPS_FAN
    tristate "Fan App"
    default n
    ---help---
        Enable the Fan App

if CUSTOM_APPS_FAN

config CUSTOM_APPS_FAN_PROGNAME
    string "Program name"
    default "fan_app"
    ---help---
        This is the name of the program that will be used when the NSH ELF
        program is installed.

config CUSTOM_APPS_FAN_PRIORITY
    int "Fan App task priority"
    default 100

config CUSTOM_APPS_FAN_STACKSIZE
    int "Fan App stack size"
    default 2048

endif
